# Copy this file to .env and fill in your values.
# The .env file is excluded from version control (.gitignore).

# Plain-text password for Tor's control port.
# The entrypoint hashes it at container startup — never baked into the image.
CONTROL_PASSWORD=changeme

# Bind address for the SOCKS5 proxy inside the container.
# Use 0.0.0.0 when your app container reaches this one over a Docker network.
# Use 127.0.0.1 if only the host needs access.
SOCKS_HOST=0.0.0.0

# Bind address for the control port inside the container.
CONTROL_HOST=0.0.0.0

# Comma-separated IP/CIDR allow-list for the SOCKS proxy.
# Default: RFC 1918 private ranges + loopback.
SOCKS_POLICY=accept 127.0.0.1,accept 10.0.0.0/8,accept 172.16.0.0/12,accept 192.168.0.0/16,reject *
